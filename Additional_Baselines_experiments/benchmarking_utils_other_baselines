# VGAE & DGI (PyG) — default-ish training loops, one-hot features used as in original notebooks
def vgae_embedding(pyg_data, k=DEFAULT_EMB_DIM, epochs=200, device='cpu'):
    device = torch.device(device)
    num_nodes = pyg_data.num_nodes
    x = torch.eye(num_nodes, device=device)
    edge_index = pyg_data.edge_index.to(device)

    class Encoder(torch.nn.Module):
        def __init__(self, in_channels, out_channels):
            super().__init__()
            self.conv1 = PyG_GCNConv(in_channels, 2 * out_channels)
            self.conv_mu = PyG_GCNConv(2 * out_channels, out_channels)
            self.conv_logstd = PyG_GCNConv(2 * out_channels, out_channels)
        def forward(self, x, edge_index):
            x = torch.relu(self.conv1(x, edge_index))
            mu = self.conv_mu(x, edge_index)
            logstd = self.conv_logstd(x, edge_index)
            return mu, logstd

    model = PyG_VGAE(Encoder(num_nodes, k)).to(device)
    opt = torch.optim.Adam(model.parameters(), lr=0.01)
    model.train()
    for _ in range(epochs):
        opt.zero_grad()
        z = model.encode(x, edge_index)
        loss = model.recon_loss(z, edge_index) + (1.0 / num_nodes) * model.kl_loss()
        loss.backward()
        opt.step()
    model.eval()
    with torch.no_grad():
        z = model.encode(x, edge_index)
    return z.detach().cpu().numpy()

def dgi_embedding(pyg_data, k=150, epochs=200, device='cpu'):
    device = torch.device(device)
    num_nodes = pyg_data.num_nodes
    x = torch.randn(num_nodes, k, device=device)  # Random initialization

    edge_index = pyg_data.edge_index.to(device)

    class GCNEncoder(torch.nn.Module):
        def __init__(self, in_channels, out_channels):
            super().__init__()
            self.conv1 = PyG_GCNConv(in_channels, 2 * out_channels)
            self.conv2 = PyG_GCNConv(2 * out_channels, out_channels)

        def forward(self, x, edge_index):
            x = torch.relu(self.conv1(x, edge_index))
            return self.conv2(x, edge_index)

    model = DeepGraphInfomax(
        hidden_channels=k,
        encoder=GCNEncoder(in_channels=k, out_channels=k),
        summary=lambda z, *args, **kwargs: torch.mean(z, dim=0),
        corruption=lambda x, edge_index: (x[torch.randperm(x.size(0))], edge_index)
    ).to(device)

    opt = torch.optim.Adam(model.parameters(), lr=0.01)
    model.train()
    for _ in range(epochs):
        opt.zero_grad()
        pos_z, neg_z, summary = model(x, edge_index)
        loss = model.loss(pos_z, neg_z, summary)
        loss.backward()
        opt.step()

    model.eval()
    with torch.no_grad():
        pos_z, _, _ = model(x, edge_index)

    return pos_z.detach().cpu().numpy()

# ----------------------------
# FUSE: modularity-based embedding (your semi_supervised_gradient_ascent_modularity)
# ----------------------------
def perform_labeled_random_walks(G, label_mask, labels, num_walks=10, walk_length=5, walk_length_labelled=3):
    walks = {node: [] for node in G.nodes()}
    nodes = list(G.nodes())
    for node in nodes:
        for _ in range(num_walks):
            walk = [node]
            labeled_count = 0
            for _ in range(walk_length - 1):
                cur = walk[-1]
                neighbors = list(G.neighbors(cur))
                if not neighbors:
                    break
                labeled_neighbors = [n for n in neighbors if label_mask[n]]
                if labeled_neighbors and labeled_count < walk_length_labelled:
                    next_node = random.choice(labeled_neighbors)
                    labeled_count += 1
                else:
                    next_node = random.choice(neighbors)
                walk.append(next_node)
            walks[node].extend([n for n in walk if label_mask[n]])
    return walks

def compute_attention_weights(S, labeled_nodes):
    weights = {}
    for node, labeled in labeled_nodes.items():
        if labeled:
            similarities = {n: float(np.dot(S[node], S[n])) for n in labeled}
            exp_sims = {n: np.exp(sim) for n, sim in similarities.items()}
            total = sum(exp_sims.values()) if len(exp_sims) > 0 else 1.0
            weights[node] = {n: exp_sims[n] / total for n in labeled}
    return weights

def fuse_embedding(G, labels, label_mask, k=DEFAULT_EMB_DIM, eta=0.01, lambda_supervised=1.0,
                   lambda_semi=2.0, iterations=200, initialization='random',
                   num_walks=10, walk_length=5, walk_length_labelled=3, seed=None):
    """
    FUSE: your semi-supervised modularity-based embedding
    Returns S (n_nodes x k) numpy array
    """
    if seed is not None:
        np.random.seed(seed)
        random.seed(seed)

    A = csr_matrix(nx.to_scipy_sparse_array(G, format='csr'))
    degrees = np.array(A.sum(axis=1)).flatten()
    m = G.number_of_edges()
    n = A.shape[0]

    if initialization == 'random':
        S = np.random.randn(n, k)
    else:
        S = np.random.randn(n, k)
    # Orthonormalize columns
    S, _ = np.linalg.qr(S)

    labeled_walks = perform_labeled_random_walks(G, label_mask, labels, num_walks, walk_length, walk_length_labelled)
    attention_weights = compute_attention_weights(S, labeled_walks)

    for _ in range(iterations):
        neighbor_agg = A @ S
        global_correction = (degrees[:, None] / (2 * m)) * S.sum(axis=0)
        grad_modularity = (1 / (2 * m)) * (neighbor_agg - global_correction)

        grad_supervised = np.zeros_like(S)
        if np.any(label_mask):
            unique_labels = np.unique(labels[label_mask])
            for lab in unique_labels:
                mask = (labels == lab) & label_mask
                if mask.sum() == 0:
                    continue
                mean_embedding = np.mean(S[mask], axis=0, keepdims=True)
                grad_supervised[mask] = S[mask] - mean_embedding

        grad_semi_supervised = np.zeros_like(S)
        for i in range(n):
            if (not label_mask[i]) and (i in attention_weights):
                weighted_embedding = sum(w * S[j] for j, w in attention_weights[i].items())
                grad_semi_supervised[i] = S[i] - weighted_embedding

        grad_total = grad_modularity - lambda_supervised * grad_supervised - lambda_semi * grad_semi_supervised
        S += eta * grad_total
        S, _ = np.linalg.qr(S)

    return S

def coles_embedding(
    G,
    k=128,
    epochs=20,
    lr=0.001,
    weight_decay=5e-4,
    K=8,
    neg_sample_ratio=2,
    seed=42,
    device="cpu"
):
    """
    COLES embedding function (drop-in replacement for DeepWalk/Node2Vec)

    Args:
        G : networkx graph
        k : embedding dimension
        epochs : training epochs
        lr : learning rate
        weight_decay : optimizer weight decay
        K : propagation steps (SSGC-style)
        neg_sample_ratio : negative samples per node
        seed : random seed
        device : cpu/cuda

    Returns:
        E : numpy array [num_nodes, k]
    """
    import time
    import numpy as np
    import scipy.sparse as sp
    import torch
    import torch.nn as nn
    import torch.nn.functional as F
    from torch_geometric.utils import from_scipy_sparse_matrix

    start = time.time()

    # ----------------------------
    # Reproducibility
    # ----------------------------
    torch.manual_seed(seed)
    np.random.seed(seed)

    device = torch.device(device)

    # ----------------------------
    # Graph → adjacency
    # ----------------------------
    A = nx.to_scipy_sparse_array(G, format="csr")
    num_nodes = A.shape[0]

    # Normalize adjacency (same as your code)
    def normalize_adj(adj):
        adj = sp.coo_matrix(adj)
        row_sum = np.array(adj.sum(1))
        d_inv_sqrt = np.power(row_sum, -0.5).flatten()
        d_inv_sqrt[np.isinf(d_inv_sqrt)] = 0.
        d_mat = sp.diags(d_inv_sqrt)
        return d_mat @ adj @ d_mat

    adj_norm = normalize_adj(A + sp.eye(num_nodes))
    lap_norm = normalize_adj(A)

    adj_norm = torch.from_numpy(adj_norm.toarray()).float().to(device)
    lap_norm = torch.from_numpy(lap_norm.toarray()).float().to(device)

    # ----------------------------
    # FEATURELESS → random init
    # ----------------------------
    feature = torch.randn((num_nodes, k)).to(device)

    # ----------------------------
    # SSGC-style propagation
    # ----------------------------
    emb = feature.clone()
    feat_tmp = feature.clone()

    for _ in range(K):
        feat_tmp = torch.mm(adj_norm, feat_tmp)
        emb += feat_tmp

    emb /= K

    # ----------------------------
    # Negative sampling (your logic)
    # ----------------------------
    def load_adj_neg(num_nodes, sample):
        col = np.random.randint(0, num_nodes, size=num_nodes * sample)
        row = np.repeat(range(num_nodes), sample)

        mask = col != row
        col = col[mask]
        row = row[mask]

        new_col = np.concatenate([col, row])
        new_row = np.concatenate([row, col])
        data = np.ones(len(new_col))

        adj_neg = sp.coo_matrix((data, (new_row, new_col)), shape=(num_nodes, num_nodes))
        adj_neg = normalize_adj(adj_neg)
        return torch.from_numpy(adj_neg.toarray()).float().to(device)

    neg_sample = load_adj_neg(num_nodes, neg_sample_ratio)

    # ----------------------------
    # Model (linear projection)
    # ----------------------------
    class Net(nn.Module):
        def __init__(self, in_dim, out_dim):
            super().__init__()
            self.fc = nn.Linear(in_dim, out_dim)

        def forward(self, x):
            return self.fc(x)

    model = Net(k, k).to(device)
    optimizer = torch.optim.Adam(model.parameters(), lr=lr, weight_decay=weight_decay)

    Lambda = 0.9

    # ----------------------------
    # Training loop
    # ----------------------------
    model.train()
    for epoch in range(epochs):
        optimizer.zero_grad()

        out = model(emb)

        loss = (
            Lambda * torch.trace(out.T @ neg_sample @ out)
            - torch.trace(out.T @ lap_norm @ out)
        ) / out.shape[0]

        loss.backward()
        optimizer.step()

    # ----------------------------
    # Final embeddings
    # ----------------------------
    model.eval()
    with torch.no_grad():
        E = model(emb).cpu().numpy()

    print(f"[COLES] Total runtime: {time.time() - start:.2f} seconds.")
    return E

def mvgrl_embedding(
    G,
    features=None,
    k=128,
    epochs=1000,
    lr=0.001,
    sample_size=2000,
    batch_size=4,
    alpha=0.2,
    device="cpu",
    seed=42,
):
    """
    Faithful MVGRL implementation (with subgraph batching)

    Returns:
        E : numpy array [N, k]
    """

    import numpy as np
    import torch
    import torch.nn as nn
    import networkx as nx
    from scipy.linalg import fractional_matrix_power, inv
    import time

    torch.manual_seed(seed)
    np.random.seed(seed)
    device = torch.device(device)

    start = time.time()

    # --------------------------------------------------
    # 1. Build adjacency + diffusion
    # --------------------------------------------------
    A = nx.to_numpy_array(G)
    N = A.shape[0]

    A_hat = A + np.eye(N)
    D = np.diag(np.sum(A_hat, axis=1))
    D_inv_sqrt = fractional_matrix_power(D, -0.5)
    A_norm = D_inv_sqrt @ A_hat @ D_inv_sqrt

    PPR = alpha * inv(np.eye(N) - (1 - alpha) * A_norm)

    # --------------------------------------------------
    # 2. Features
    # --------------------------------------------------
    if features is None:
        X = np.random.randn(N, k)
        in_dim = k
    else:
        X = features
        in_dim = X.shape[1]

    # --------------------------------------------------
    # 3. Model (matches original)
    # --------------------------------------------------
    class GCN(nn.Module):
        def __init__(self, in_ft, out_ft):
            super().__init__()
            self.fc = nn.Linear(in_ft, out_ft, bias=False)
            self.act = nn.PReLU()

        def forward(self, seq, adj):
            seq = self.fc(seq)
            return self.act(torch.bmm(adj, seq))

    class Readout(nn.Module):
        def forward(self, seq):
            return torch.mean(seq, dim=1)

    class Discriminator(nn.Module):
        def __init__(self, dim):
            super().__init__()
            self.f_k = nn.Bilinear(dim, dim, 1)

        def forward(self, c1, c2, h1, h2, h3, h4):
            c1 = c1.unsqueeze(1).expand_as(h1)
            c2 = c2.unsqueeze(1).expand_as(h2)

            pos1 = self.f_k(h2, c1).squeeze(-1)
            pos2 = self.f_k(h1, c2).squeeze(-1)

            neg1 = self.f_k(h4, c1).squeeze(-1)
            neg2 = self.f_k(h3, c2).squeeze(-1)

            return torch.cat([pos1, pos2, neg1, neg2], dim=1)

    class MVGRL(nn.Module):
        def __init__(self, in_dim, hid_dim):
            super().__init__()
            self.gcn1 = GCN(in_dim, hid_dim)
            self.gcn2 = GCN(in_dim, hid_dim)
            self.read = Readout()
            self.sigm = nn.Sigmoid()
            self.disc = Discriminator(hid_dim)

        def forward(self, x, x_shuf, adj, diff):
            h1 = self.gcn1(x, adj)
            h2 = self.gcn2(x, diff)

            c1 = self.sigm(self.read(h1))
            c2 = self.sigm(self.read(h2))

            h3 = self.gcn1(x_shuf, adj)
            h4 = self.gcn2(x_shuf, diff)

            logits = self.disc(c1, c2, h1, h2, h3, h4)
            return logits, h1, h2

        def embed(self, x, adj, diff):
            h1 = self.gcn1(x, adj)
            h2 = self.gcn2(x, diff)
            return (h1 + h2)

    model = MVGRL(in_dim, k).to(device)
    optimizer = torch.optim.Adam(model.parameters(), lr=lr)
    bce = nn.BCEWithLogitsLoss()

    # --------------------------------------------------
    # 4. Training (SUBGRAPH BATCHING — key part)
    # --------------------------------------------------
    for epoch in range(epochs):

        # sample random subgraphs
        idx = np.random.randint(0, N - sample_size + 1, batch_size)

        ba, bd, bf = [], [], []

        for i in idx:
            ba.append(A_norm[i:i+sample_size, i:i+sample_size])
            bd.append(PPR[i:i+sample_size, i:i+sample_size])
            bf.append(X[i:i+sample_size])

        ba = torch.FloatTensor(np.array(ba)).to(device)
        bd = torch.FloatTensor(np.array(bd)).to(device)
        bf = torch.FloatTensor(np.array(bf)).to(device)

        # shuffle features (negative samples)
        perm = torch.randperm(sample_size)
        shuf = bf[:, perm, :]

        logits, _, _ = model(bf, shuf, ba, bd)

        # labels
        lbl_1 = torch.ones(batch_size, sample_size * 2)
        lbl_2 = torch.zeros(batch_size, sample_size * 2)
        lbl = torch.cat([lbl_1, lbl_2], dim=1).to(device)

        loss = bce(logits, lbl)

        optimizer.zero_grad()
        loss.backward()
        optimizer.step()

        if (epoch + 1) % max(1, epochs // 5) == 0:
            print(f"[MVGRL] Epoch {epoch+1}/{epochs} | Loss {loss.item():.4f}")

    # --------------------------------------------------
    # 5. Final embeddings (FULL graph)
    # --------------------------------------------------
    model.eval()

    A_t = torch.FloatTensor(A_norm[np.newaxis]).to(device)
    P_t = torch.FloatTensor(PPR[np.newaxis]).to(device)
    X_t = torch.FloatTensor(X[np.newaxis]).to(device)

    with torch.no_grad():
        E = model.embed(X_t, A_t, P_t)[0].cpu().numpy()

    print(f"[MVGRL] Total runtime: {time.time() - start:.2f}s")

    return E


def cca_ssg_embedding(
    pyg_data,
    k=128,
    epochs=100,
    lr=1e-3,
    weight_decay=0.0,
    lambd=1e-3,
    n_layers=2,
    drop_edge_rate=0.2,
    drop_feature_rate=0.2,
    device="cpu",
    seed=42
):
    """
    CCA-SSG embedding (adapted for featureless graphs + your pipeline)

    Args:
        pyg_data : torch_geometric.data.Data
        k : embedding dimension
        epochs : training epochs
        lr : learning rate
        lambd : decorrelation weight
        drop_edge_rate : edge dropout
        drop_feature_rate : feature dropout
        device : cpu/cuda

    Returns:
        E : numpy array [num_nodes, k]
    """
    import time
    import torch
    import torch.nn as nn
    import torch.nn.functional as F
    from torch_geometric.nn import GCNConv
    from torch_geometric.utils import dropout_edge
    import numpy as np

    # ----------------------------
    # Reproducibility
    # ----------------------------
    torch.manual_seed(seed)
    np.random.seed(seed)
    device = torch.device(device)

    n = pyg_data.num_nodes
    edge_index = pyg_data.edge_index.to(device)

    # ----------------------------
    # FEATURELESS → random init
    # ----------------------------
    x = torch.randn((n, k), device=device)

    # ----------------------------
    # Encoder (GCN)
    # ----------------------------
    class GCN(nn.Module):
        def __init__(self, in_dim, hid_dim, out_dim, n_layers):
            super().__init__()
            self.convs = nn.ModuleList()
            self.convs.append(GCNConv(in_dim, hid_dim))

            for _ in range(n_layers - 2):
                self.convs.append(GCNConv(hid_dim, hid_dim))

            self.convs.append(GCNConv(hid_dim, out_dim))

        def forward(self, x, edge_index):
            for conv in self.convs[:-1]:
                x = F.relu(conv(x, edge_index))
            x = self.convs[-1](x, edge_index)
            return x

    model = GCN(k, 2 * k, k, n_layers).to(device)
    optimizer = torch.optim.Adam(model.parameters(), lr=lr, weight_decay=weight_decay)

    # ----------------------------
    # Augmentations
    # ----------------------------
    def drop_feature(x, drop_prob):
        mask = torch.rand(x.size(1), device=x.device) < drop_prob
        x = x.clone()
        x[:, mask] = 0
        return x

    def augment(x, edge_index):
        e, _ = dropout_edge(edge_index, p=drop_edge_rate)
        x_aug = drop_feature(x, drop_feature_rate)
        return x_aug, e

    print(f"[CCA-SSG] Training | epochs={epochs}")

    start = time.time()

    # ----------------------------
    # Training loop
    # ----------------------------
    model.train()
    for epoch in range(epochs):
        optimizer.zero_grad()

        # Two augmented views
        x1, e1 = augment(x, edge_index)
        x2, e2 = augment(x, edge_index)

        h1 = model(x1, e1)
        h2 = model(x2, e2)

        # Normalize (important for CCA)
        z1 = (h1 - h1.mean(0)) / (h1.std(0) + 1e-9)
        z2 = (h2 - h2.mean(0)) / (h2.std(0) + 1e-9)

        N = n

        # Cross-correlation
        c = torch.mm(z1.T, z2) / N
        c1 = torch.mm(z1.T, z1) / N
        c2 = torch.mm(z2.T, z2) / N

        # Loss
        loss_inv = -torch.diagonal(c).sum()

        I = torch.eye(k, device=device)
        loss_dec1 = (I - c1).pow(2).sum()
        loss_dec2 = (I - c2).pow(2).sum()

        loss = loss_inv + lambd * (loss_dec1 + loss_dec2)

        loss.backward()
        optimizer.step()

        if (epoch + 1) % max(1, epochs // 5) == 0:
            print(f"  Epoch {epoch+1:03d}/{epochs} | Loss = {loss.item():.4f}")

    # ----------------------------
    # Final embeddings
    # ----------------------------
    model.eval()
    with torch.no_grad():
        E = model(x, edge_index).cpu().numpy()

    print(f"[CCA-SSG] Total runtime: {time.time() - start:.2f} seconds.")
    return E


